# Copy this file to .env and fill in real values. Never commit .env itself.
# Every variable read by the app is declared in backend/config.py (Settings).
# For local dev, load this file explicitly:
#   uv run uvicorn backend.main:app --reload --env-file .env
# (docker-compose injects these automatically.)

# ─── LLM provider ────────────────────────────────────────────────────────────
# Which provider the agent layer uses — "groq" (primary) or "nvidia" (fallback).
# See backend/agents/llm_client.py.
LLM_PROVIDER=groq

# Required if LLM_PROVIDER=groq
GROQ_API_KEY=

# Required if LLM_PROVIDER=nvidia
NVIDIA_API_KEY=

# ─── API ─────────────────────────────────────────────────────────────────────
# Allowed CORS origins, as a JSON array. Defaults to ["*"] if unset. Lock this
# to the deployed frontend origin in production.
# Example: CORS_ALLOW_ORIGINS=["https://opportunity-copilot.example.com"]
CORS_ALLOW_ORIGINS=["*"]
